# =========================================
# chart-pattern-alert — Environment (sample)
# =========================================
# このファイルはダミー値のみ。本物の値は .env にコピーして編集してください。
# .env は .gitignore 済み。

# -------------------
# Frontend (Vite)
# -------------------
# 本番(GitHub Pages)からアクセスする API の URL。
# 上流プロキシ経由で HTTPS 化された公開 URL を想定。開発時は http://localhost:8000。
VITE_API_BASE_URL=http://localhost:8000

# -------------------
# API (FastAPI)
# -------------------
# カンマ区切りで許可オリジンを指定。
# 本番: GitHub Pages オリジン + 上流プロキシ経由の公開オリジン。
# 開発: Vite dev server (http://localhost:5173) を追加。
CORS_ORIGINS=https://reisun.github.io,http://localhost:5173

# OHLCV キャッシュの TTL(秒)。短すぎると API 叩き過ぎ、長すぎると鮮度落ちる。
# 5分足ポーリング前提なら 60〜120 秒が妥当。
CACHE_TTL_SECONDS=90

# yfinance 取得に使う既定リージョン/市場の最大取得範囲(上限ガード)。
# 例: "5m" 足は 60 日までに制限される等。
MAX_RANGE_DAYS=60

# OHLCV データソース。"finnhub", "alphavantage", "yfinance" から選択。
# Finnhub は分足対応でデフォルト推奨。
DATA_SOURCE=finnhub

# Finnhub API キー。finnhub データソース利用時に必要。
# https://finnhub.io/ で無料キーを取得可能。
# 無料枠: 60リクエスト/分。
FINNHUB_API_KEY=

# Alpha Vantage API キー。alphavantage データソース利用時に必要。
# https://www.alphavantage.co/support/#api-key で無料キーを取得可能。
# 無料枠: 25リクエスト/日, 5リクエスト/分。
ALPHA_VANTAGE_API_KEY=
